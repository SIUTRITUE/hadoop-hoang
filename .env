# Hadoop Configuration
HADOOP_VERSION=3.3.6
JAVA_VERSION=11

# Spark Configuration
SPARK_VERSION=3.5.0

# Resource Configuration
HADOOP_HEAPSIZE=1024
SPARK_EXECUTOR_MEMORY=1g
SPARK_EXECUTOR_CORES=2
SPARK_DRIVER_MEMORY=1g

# Network Configuration
DOCKER_NETWORK=hadoop-spark-network

# Container Names
HADOOP_MASTER=hadoop-master
HADOOP_WORKER_1=hadoop-worker-1
HADOOP_WORKER_2=hadoop-worker-2
SPARK_MASTER=spark-master
SPARK_WORKER_1=spark-worker-1
SPARK_WORKER_2=spark-worker-2
JUPYTER=jupyter-notebook

# Port Configuration
NAMENODE_PORT=9870
YARN_PORT=8088
SPARK_MASTER_PORT=8080
SPARK_WORKER_PORT=8081
JUPYTER_PORT=8888
