<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>

<configuration>
    <!-- Resource Manager Configuration -->
    <property>
        <name>yarn.resourcemanager.hostname</name>
        <value>hadoop-master</value>
    </property>

    <!-- Resource Manager web UI -->
    <property>
        <name>yarn.resourcemanager.webapp.address</name>
        <value>0.0.0.0:8088</value>
    </property>

    <!-- Node Manager Configuration -->
    <property>
        <name>yarn.nodemanager.aux-services</name>
        <value>mapreduce_shuffle</value>
    </property>

    <property>
        <name>yarn.nodemanager.aux-services.mapreduce_shuffle.class</name>
        <value>org.apache.hadoop.mapreduce.v2.shuffle.ShuffleHandler</value>
    </property>

    <!-- Node Manager web UI binding address -->
    <property>
        <name>yarn.nodemanager.webapp.address</name>
        <value>0.0.0.0:8042</value>
    </property>

    <!-- Node Manager local directories -->
    <property>
        <name>yarn.nodemanager.local-dirs</name>
        <value>/data/tmp/nm-local-dir</value>
    </property>

    <!-- Node Manager log directories -->
    <property>
        <name>yarn.nodemanager.log-dirs</name>
        <value>/data/tmp/nm-logs</value>
    </property>

    <!-- Resource Manager RPC Address -->
    <property>
        <name>yarn.resourcemanager.address</name>
        <value>hadoop-master:8032</value>
    </property>

    <!-- Resource Scheduler Address -->
    <property>
        <name>yarn.resourcemanager.scheduler.address</name>
        <value>hadoop-master:8030</value>
    </property>

    <!-- Resource Manager Resource Tracker Address -->
    <property>
        <name>yarn.resourcemanager.resource-tracker.address</name>
        <value>hadoop-master:8031</value>
    </property>

    <!-- Node Manager Memory -->
    <property>
        <name>yarn.nodemanager.resource.memory-mb</name>
        <value>2048</value>
    </property>

    <!-- Node Manager Virtual Cores -->
    <property>
        <name>yarn.nodemanager.resource.cpu-vcores</name>
        <value>2</value>
    </property>

    <!-- Job History Server Configuration -->
    <property>
        <name>mapreduce.jobhistory.address</name>
        <value>hadoop-master:10020</value>
    </property>

    <property>
        <name>mapreduce.jobhistory.webapp.address</name>
        <value>hadoop-master:19888</value>
    </property>

    <!-- MapReduce Configuration -->
    <property>
        <name>mapreduce.framework.name</name>
        <value>yarn</value>
    </property>

    <property>
        <name>mapreduce.map.memory.mb</name>
        <value>512</value>
    </property>

    <property>
        <name>mapreduce.reduce.memory.mb</name>
        <value>512</value>
    </property>

    <!-- Allow Spark to run on YARN -->
    <property>
        <name>yarn.application.classpath</name>
        <value>$HADOOP_HOME/etc/hadoop:$HADOOP_HOME/share/hadoop/common:$HADOOP_HOME/share/hadoop/common/lib/*:$HADOOP_HOME/share/hadoop/hdfs:$HADOOP_HOME/share/hadoop/hdfs/lib/*:$HADOOP_HOME/share/hadoop/yarn:$HADOOP_HOME/share/hadoop/yarn/lib/*</value>
    </property>
</configuration>
