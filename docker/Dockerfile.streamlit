FROM jupyter/pyspark-notebook:python-3.10

WORKDIR /app

USER root

# Copy app files
COPY streamlit/ /app/

# Install Streamlit and additional packages
RUN pip install --no-cache-dir \
    streamlit==1.28.0 \
    plotly==5.17.0 \
    pyspark==3.5.0

USER jovyan

EXPOSE 8501

CMD ["streamlit", "run", "app.py", "--server.port=8501", "--server.address=0.0.0.0"]
